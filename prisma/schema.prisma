generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  needType  String
  clients   String?
  message   String?
  createdAt DateTime @default(now())
  
  @@map("contacts")
}
